# Clerk runs in keyless mode during local development if these are unset.
# Add values here later only if you want to use your own Clerk instance.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:5432/DB_NAME"

# App theme behavior:
# NEXT_PUBLIC_THEME_MODE sets the initial/default theme: light, dark, or system
# NEXT_PUBLIC_ENABLE_THEME_TOGGLE can be: true or false
# Set NEXT_PUBLIC_ENABLE_THEME_TOGGLE=false to lock the app to the selected mode.
NEXT_PUBLIC_THEME_MODE=light
NEXT_PUBLIC_ENABLE_THEME_TOGGLE=true
